bob_import_cc {
    name: "import_lib_a",
    includes: [
        "libA/includes",
    ],
    target: "target",
    defines: [
        "FOO",
    ],
    linkopts: [
        "-shared",
    ],
    src: "liba.a",
}

bob_shared_library {
    name: "shared_lib",
    srcs: [
        "main.cpp",
    ],
    shared_libs: [
        "import_lib_a",
    ],
}
