load("@rules_foreign_cc//foreign_cc:defs.bzl", "cmake")

filegroup(
    name = "srcs",
    srcs = [
        "CMakeLists.txt",
        "api.h",
        "impl.c",
    ],
)

cmake(
    name = "shared",
    copts = ["-DVALUE_A=19"],
    defines = ["VALUE_SUM=22"],
    lib_source = ":srcs",
    out_shared_libs = ["libcmake_test_shared.so"],
    visibility = [
        "//tests/bazel_cc_import/bazel:__pkg__",
        "//tests/bazel_cc_import/bazel/binary:__subpackages__",
    ],
)

cmake(
    name = "static",
    copts = ["-DVALUE_A=19"],
    defines = ["VALUE_SUM=22"],
    lib_source = ":srcs",
    out_static_libs = ["libcmake_test_static.a"],
    visibility = ["//tests/bazel_cc_import/bazel:__pkg__"],
)

cmake(
    name = "multiple",
    copts = ["-DVALUE_A=19"],
    defines = ["VALUE_SUM=22"],
    lib_source = ":srcs",
    out_shared_libs = ["libcmake_test_shared.so"],
    out_static_libs = ["libcmake_test_static.a"],
    visibility = ["//tests/bazel_cc_import/bazel:__pkg__"],
)
