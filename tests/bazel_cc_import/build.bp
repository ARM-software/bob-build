bob_genrule {
    name: "bob_test_bazel_cc_import_binary_genrule_tool",
    out: ["bazel_imported_tool_output.txt"],
    tools: ["tests_bazel_cc_import_bazel_binary_tool_tool"],
    cmd: "actual=0; ${location} || actual=$$?; test \"$$actual\" = 42; printf '%s\\n' \"$$actual\" > ${out}",
}

