bob_import_cc_library {
    name: "import_lib_a",
    includes: [
        "libA/includes",
    ],
    target: "target",
}

bob_import_cc_library {
    name: "import_lib_b",
    includes: [
        "libB/includes",
    ],
    target: "target",
}

bob_shared_library {
    name: "bob_test_import_headeronly_lib",
    srcs: [
        "main.cpp",
    ],
    shared_libs: [
        "import_lib_a",
        "import_lib_b",
    ],
    cflags: [
        "-fPIC",
    ],
    ldflags: [
        "-fPIC",
    ],
}
